# Option 1: Use GitHub Copilot (recommended if you have a Copilot subscription)
GITHUB_TOKEN=ghp-your-github-pat-here

# Option 2: Use OpenAI API directly (only needed if GITHUB_TOKEN is not set)
# OPENAI_API_KEY=sk-your-key-here

# Model selection (optional — these are the defaults)
# MODEL_NAME=gpt-4o
# EMBEDDING_MODEL=text-embedding-3-large
#
# Other models available via GitHub Models (Enterprise):
#   Chat: gpt-4o, gpt-4o-mini, o3-mini, o1-mini
#   Embedding: text-embedding-3-large, text-embedding-3-small
